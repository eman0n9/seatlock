<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="02-update-activity" author="admin">

        <addUniqueConstraint tableName="activity" columnNames="name" constraintName="uq_activity_name"/>

        <rollback>
            <dropUniqueConstraint tableName="activity" constraintName="uq_activity_name"/>
        </rollback>
    </changeSet>
</databaseChangeLog>